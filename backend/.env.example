# =============================================================
#  NeoCampus Backend — Environment Variables
#  Copy this file to `.env` and fill in the values.
#  Run: cp .env.example .env
# =============================================================


# ─────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────

# Set to False in production
DEBUG=True

# Django secret key — used for session signing, CSRF tokens, etc.
# HOW TO GET: Generate a new one by running:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# NOTE: Each developer can use their own key locally.
#       In production, all servers must share the SAME key.
SECRET_KEY=your-django-secret-key-here


# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────

# HOW TO GET: Install PostgreSQL on your system and create a database.
#   1. Open pgAdmin or psql
#   2. Create a database: CREATE DATABASE neocampus;
#   3. Fill in your local PostgreSQL credentials below.
DB_NAME=neocampus
DB_USER=postgres
DB_PASSWORD=your-postgres-password-here
DB_HOST=localhost
DB_PORT=5432


# ─────────────────────────────────────────────
# ALLOWED HOSTS
# ─────────────────────────────────────────────

# Comma-separated list of allowed hosts.
# Use * for local development only. Set specific domains in production.
ALLOWED_HOSTS=*


# ─────────────────────────────────────────────
# GEMINI API KEYS (Google Generative AI)
# ─────────────────────────────────────────────

# Used for: Chatbot feature
# HOW TO GET:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Sign in with your Google account
#   3. Click "Create API Key" and copy it here
GEMINI_API_KEY=your-gemini-api-key-for-chatbot

# Used for: Result Analysis feature
# HOW TO GET: Same as above — create a second API key (or reuse the same one)
GEMINI_API_KEY2=your-gemini-api-key-for-result-analysis


# ─────────────────────────────────────────────
# VAPID KEYS (Web Push Notifications)
# ─────────────────────────────────────────────

# Used for sending browser push notifications to users.
# IMPORTANT: All developers working on the SAME deployment must use
#            the SAME VAPID keys. Changing them invalidates all
#            existing push subscriptions.
#
# HOW TO GET:
#   Option 1 — Contact the project owner (sarangwagh04) for the shared keys.
#
#   Option 2 — Generate your own (for isolated local dev only):
#     1. pip install py-vapid
#     2. python -c "
#          from py_vapid import Vapid
#          v = Vapid()
#          v.generate_keys()
#          print('Private:', v.private_key)
#          print('Public:', v.public_key)
#        "
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_PUBLIC_KEY=your-vapid-public-key-here
